.confirm-btn-wrap{margin-top:12px}

/* ===================== ANIMATIONS ===================== */
@keyframes slideIn{
  from{opacity:0;transform:translateY(16px) scale(0.97)}
  to{opacity:1;transform:translateY(0) scale(1)}
}
.animate-in{animation:slideIn 0.3s cubic-bezier(0.34,1.12,0.64,1) forwards}

@keyframes pulseBorder{
  0%,100%{box-shadow:0 5px 18px rgba(0,0,0,0.22), 0 0 0 0 rgba(245,192,24,0.45)}
  50%{box-shadow:0 5px 18px rgba(0,0,0,0.22), 0 0 0 6px rgba(245,192,24,0.12)}
}
.pulse{animation:pulseBorder 2.2s infinite}

@keyframes tropicalSway{
  0%,100%{transform:rotate(-2deg) scale(1)}
  50%{transform:rotate(2deg) scale(1.05)}
}
@keyframes flameFlicker{
  0%,100%{opacity:1;transform:scale(1) translateY(0)}
  33%{opacity:0.85;transform:scale(0.97) translateY(-1px)}
  66%{opacity:0.9;transform:scale(1.02) translateY(1px)}
}

/* ===================== WIN SCREEN ===================== */
.win-trophy{
