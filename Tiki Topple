<script>
const TIKI_COLORS = [
  {name:'Red',bg:'#E24B4A',text:'#FCEBEB'},
  {name:'Orange',bg:'#D85A30',text:'#FAECE7'},
  {name:'Yellow',bg:'#EF9F27',text:'#412402'},
  {name:'Green',bg:'#3B6D11',text:'#EAF3DE'},
  {name:'Blue',bg:'#185FA5',text:'#E6F1FB'},
  {name:'Purple',bg:'#7F77DD',text:'#26215C'},
  {name:'Pink',bg:'#D4537E',text:'#FBEAF0'},
  {name:'Grey',bg:'#888780',text:'#F1EFE8'},
  {name:'Brown',bg:'#854F0B',text:'#FAEEDA'},
];
const PAWN_COLORS = ['#534AB7','#D85A30','#1D9E75','#D4537E'];
const PAWN_NAMES = ['Violet','Ember','Jade','Rose'];
const CARDS = ['Tiki 1 Up','Tiki 2 Up','Tiki 3 Up','Tiki Topple','Tiki Toast'];
const CARD_ICONS = {'Tiki 1 Up':'1↑','Tiki 2 Up':'2↑','Tiki 3 Up':'3↑','Tiki Topple':'↓↓','Tiki Toast':'✕'};
const WIN_SCORE = 35;
let G = {};

function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  const el = document.getElementById('screen-'+id);
  el.classList.add('active');
  el.querySelectorAll('.animate-in').forEach(e=>{e.style.animation='none';e.offsetHeight;e.style.animation=''});
}

function setPlayers(n){
  G.numPlayers=n;
  document.querySelectorAll('#player-count-btns .btn').forEach((b,i)=>{
    b.classList.toggle('active', i===n-2);
  });
  event.target.classList.add('active');
  renderSetupInputs(n);
}

function renderSetupInputs(n){
  let html='';
  for(let i=0;i<n;i++){
    html+=`<div class="player-setup-row">
      <div class="pawn-dot" style="background:${PAWN_COLORS[i]}"></div>
      <input class="tt-input" type="text" placeholder="Player ${i+1} name" id="pname-${i}" value="${PAWN_NAMES[i]}">
    </div>`;
  }
  document.getElementById('player-setup-area').innerHTML=html;
  document.getElementById('start-btn').style.display='flex';
}

function startGame(){
  G.players=[];
  for(let i=0;i<G.numPlayers;i++){
    const nm=document.getElementById('pname-'+i).value.trim()||`Player ${i+1}`;
    G.players.push({name:nm,color:PAWN_COLORS[i],score:0,cards:[...CARDS],usedCards:[],secret:null});
  }
  assignSecrets();
  G.round=1; G.globalTurn=0; G.secretIdx=0;
  initBoard();
  showNextSecret();
}

function assignSecrets(){
  const indices=Array.from({length:9},(_,i)=>i);
  G.players.forEach(p=>{
    const pool=[...indices],picks=[];
    for(let i=0;i<3;i++){const r=Math.floor(Math.random()*pool.length);picks.push(pool.splice(r,1)[0]);}
    p.secret=picks;
  });
}

function initBoard(){
  const shuffled=[...TIKI_COLORS].sort(()=>Math.random()-0.5);
  G.board=shuffled.map(t=>({...t,removed:false}));
  G.removedThisRound=false;
}

function showNextSecret(){
  if(G.secretIdx>=G.players.length){G.secretIdx=0;showGame();return;}
  const p=G.players[G.secretIdx];
  document.getElementById('sc-round').textContent=G.round;
  document.getElementById('sc-player-name').textContent=p.name;
  document.getElementById('sc-player-name').style.color='#FAC775';
  document.getElementById('sc-card-reveal').style.display='none';
  document.getElementById('sc-cover').style.display='flex';
  document.getElementById('sc-next-btn').style.display='none';
  renderSecretCard(p);
  show('secret');
}

function renderSecretCard(p){
  const labels=['Secret 1','Secret 2','Secret 3'];
  const pts=['+9 pts if at #1','+5 pts if at #1–2','+2 pts if at #1–3'];
  const badgeColors=[
    {bg:'#FAEEDA',text:'#633806'},
    {bg:'#EEEDFE',text:'#3C3489'},
    {bg:'#E1F5EE',text:'#085041'},
  ];
  let html='';
  p.secret.forEach((idx,i)=>{
    const t=TIKI_COLORS[idx];
    const bc=badgeColors[i];
    html+=`<div class="secret-tiki-row">
      <div style="width:34px;height:34px;border-radius:8px;background:${t.bg};flex-shrink:0;box-shadow:0 2px 6px rgba(0,0,0,0.18)"></div>
      <div style="flex:1">
        <div style="font-size:13px;font-weight:500">${t.name}</div>
        <div style="font-size:11px;color:var(--tt-muted)">${pts[i]}</div>
      </div>
      <div class="secret-badge" style="background:${bc.bg};color:${bc.text}">${labels[i]}</div>
    </div>`;
  });
  document.getElementById('sc-tikis').innerHTML=html;
}

function revealSecret(){
  document.getElementById('sc-cover').style.display='none';
  document.getElementById('sc-card-reveal').style.display='block';
  document.getElementById('sc-next-btn').style.display='flex';
}

function nextSecretOrPlay(){G.secretIdx++;showNextSecret();}

function currentPlayer(){return G.players[G.globalTurn%G.numPlayers];}

function showGame(){
  renderBoard(); renderCards(); renderPlayers(); updateGameHeader();
  document.getElementById('g-action-area').innerHTML='';
  document.getElementById('g-log').innerHTML='Select a card to play.';
  show('game');
  G.selectedCard=null; G.selectedTikiIdx=null;
}

function updateGameHeader(){
  const p=currentPlayer();
  document.getElementById('g-round').textContent=G.round;
  document.getElementById('g-turn').textContent=G.globalTurn+1;
  document.getElementById('g-current-name').textContent=p.name+"'s turn";
  document.getElementById('g-current-name').style.color=p.color;
}

function renderBoard(){
  const el=document.getElementById('g-board');
  const active=G.board.filter(t=>!t.removed);
  let html='';
  active.forEach((t,i)=>{
    const pos=i+1;
    const selBoardIdx=G.board.indexOf(t);
    const sel=G.selectedTikiIdx!==null&&selBoardIdx===G.selectedTikiIdx;
    const posClass=pos===1?'top1':pos<=3?'top3':'';
    html+=`<div class="tiki-piece" onclick="selectTiki(${selBoardIdx})"
      style="background:${t.bg}18;border-color:${sel?t.bg:'transparent'}">
      <div class="tiki-pos ${posClass}">${pos}</div>
      <div class="tiki-face" style="background:${t.bg};color:${t.text}">${t.name.slice(0,2)}</div>
      <div class="tiki-name" style="color:var(--tt-text);font-size:13px">${t.name}</div>
    </div>`;
  });
  if(!active.length)html='<p style="font-size:12px;color:var(--tt-muted);text-align:center;padding:8px">All tikis toasted!</p>';
  el.innerHTML=html;
}

function renderCards(){
  const p=currentPlayer();
  const el=document.getElementById('g-cards');
  let html='';
  CARDS.forEach(c=>{
    const used=p.usedCards.includes(c);
    const sel=G.selectedCard===c;
    html+=`<button onclick="selectCard('${c}')" ${used?'disabled':''} class="card-pill${sel?' selected':''}" data-card="${c}">
      <div class="card-icon">${CARD_ICONS[c]}</div>
      <span style="${used?'text-decoration:line-through':''}">${c}</span>
      ${used?'<span style="font-size:11px;color:var(--tt-muted);margin-left:auto">used</span>':''}
    </button>`;
  });
  el.innerHTML=html;
}

function renderPlayers(){
  const el=document.getElementById('g-players-panel');
  let html='';
  G.players.forEach((p,i)=>{
    const isCur=G.globalTurn%G.numPlayers===i;
    const pct=Math.min(100,Math.round(p.score/WIN_SCORE*100));
    const cardsLeft=5-p.usedCards.length;
    let pips='';
    for(let j=0;j<5;j++){
      const used=p.usedCards.length>j;
      pips+=`<div class="player-pip" style="background:${used?p.color+'55':p.color};border:1.5px solid ${p.color}"></div>`;
    }
    html+=`<div class="player-panel${isCur?' active pulse':''}" style="${isCur?`border-color:${p.color}`:''}">
      <div class="player-name-row">
        <div class="player-dot" style="background:${p.color}"></div>
        <span style="font-size:13px;font-weight:500">${p.name}</span>
        ${isCur?`<span style="font-size:10px;background:${p.color}22;color:${p.color};padding:1px 6px;border-radius:20px;margin-left:auto">playing</span>`:''}
      </div>
      <div class="player-score" style="color:${p.color}">${p.score}</div>
      <div style="font-size:10px;color:var(--tt-muted)">${cardsLeft} card${cardsLeft!==1?'s':''} left</div>
      <div class="score-bar-bg"><div class="score-bar-fill" style="width:${pct}%;background:${p.color}"></div></div>
      <div class="player-pip-row">${pips}</div>
    </div>`;
  });
  el.innerHTML=html;
}

function selectCard(c){
  const p=currentPlayer();
  if(p.usedCards.includes(c))return;
  G.selectedCard=c; G.selectedTikiIdx=null;
  renderCards();
  if(c==='Tiki Toast'){
    document.getElementById('g-log').innerHTML=`<strong>Tiki Toast</strong> will remove the bottom tiki from the round.`;
    document.getElementById('g-action-area').innerHTML=`<button class="btn accent" onclick="confirmToast()" style="width:100%;padding:9px">Confirm Tiki Toast</button>`;
  } else {
    document.getElementById('g-log').innerHTML=`<strong>${c}</strong> selected — now tap a tiki on the board to target it.`;
    document.getElementById('g-action-area').innerHTML='';
  }
  renderBoard();
}

function selectTiki(idx){
  if(!G.selectedCard){document.getElementById('g-log').innerHTML='Select a card first.';return;}
  if(G.selectedCard==='Tiki Toast')return;
  const t=G.board[idx];
  if(t.removed)return;
  G.selectedTikiIdx=idx;
  renderBoard();
  document.getElementById('g-action-area').innerHTML=`<button class="btn accent" onclick="confirmMove()" style="width:100%;padding:9px">Confirm — move ${t.name}</button>`;
  document.getElementById('g-log').innerHTML=`Moving <strong>${t.name}</strong> with <strong>${G.selectedCard}</strong>.`;
}

function getActiveStack(){return G.board.reduce((a,t,i)=>(!t.removed?[...a,i]:[...a]),[]);}

function confirmToast(){
  const stack=getActiveStack();
  if(!stack.length){document.getElementById('g-log').innerHTML='No tikis left!';return;}
  const bottomIdx=stack[stack.length-1];
  G.board[bottomIdx].removed=true;
  G.removedThisRound=true;
  finishTurn('Tiki Toast',`<strong>${G.board[bottomIdx].name}</strong> removed from the bottom.`);
}

function confirmMove(){
  if(G.selectedTikiIdx===null)return;
  const card=G.selectedCard;
  const stack=getActiveStack();
  const posInStack=stack.indexOf(G.selectedTikiIdx);
  if(posInStack===-1)return;
  let steps=0;
  if(card==='Tiki 1 Up')steps=1;
  else if(card==='Tiki 2 Up')steps=2;
  else if(card==='Tiki 3 Up')steps=3;
  else if(card==='Tiki Topple'){
    const t=G.board.splice(G.selectedTikiIdx,1)[0];
    G.board.push(t);
    finishTurn('Tiki Topple',`<strong>${t.name}</strong> sent to the bottom.`);
    return;
  }
  const newPos=Math.max(0,posInStack-steps);
  const tikiObj=G.board.splice(G.selectedTikiIdx,1)[0];
  const newStack=getActiveStack();
  let insertBefore=newStack[newPos];
  if(insertBefore===undefined){G.board.push(tikiObj);}
  else{if(insertBefore>=G.selectedTikiIdx)insertBefore--;G.board.splice(insertBefore,0,tikiObj);}
  finishTurn(card,`<strong>${tikiObj.name}</strong> moved up ${steps} position${steps>1?'s':''}.`);
}

function finishTurn(card,logMsg){
  const p=currentPlayer();
  p.usedCards.push(card);
  G.selectedCard=null; G.selectedTikiIdx=null;
  G.globalTurn++;
  const totalTurnsPerRound=G.numPlayers*5;
  const turnsInRound=G.globalTurn-(G.round-1)*totalTurnsPerRound;
  if(turnsInRound>=totalTurnsPerRound){endRound(logMsg);}
  else{document.getElementById('g-log').innerHTML=logMsg;showGame();}
}

function endRound(lastMsg){
  const roundScores=scoreRound();
  document.getElementById('re-round').textContent=G.round;
  renderRoundEndBoard();
  renderRoundScores(roundScores);
  const winner=G.players.find(p=>p.score>=WIN_SCORE);
  document.getElementById('re-continue-btn').textContent=winner?'See final results':'Start next round';
  show('round-end');
}

function scoreRound(){
  const stack=getActiveStack();
  const results=[];
  G.players.forEach(p=>{
    let r1=0,r2=0,r3=0;
    const pos1=stackPosOf(p.secret[0]);
    const pos2=stackPosOf(p.secret[1]);
    const pos3=stackPosOf(p.secret[2]);
    if(pos1===1)r1=9;
    if(pos2>=1&&pos2<=2)r2=5;
    if(pos3>=1&&pos3<=3)r3=2;
    const earned=r1+r2+r3;
    p.score+=earned;
    results.push({player:p,earned,r1,r2,r3,pos1,pos2,pos3});
  });
  return results;
}

function stackPosOf(colorIdx){
  const stack=getActiveStack();
  const target=TIKI_COLORS[colorIdx].name;
  for(let i=0;i<stack.length;i++){if(G.board[stack[i]].name===target)return i+1;}
  return -1;
}

function renderRoundEndBoard(){
  const stack=getActiveStack();
  let html='<div style="display:flex;flex-direction:column;gap:3px">';
  stack.forEach((idx,i)=>{
    const t=G.board[idx];
    const pos=i+1;
    const posClass=pos===1?'top1':pos<=3?'top3':'';
    html+=`<div class="round-tiki-row" style="background:${t.bg}18">
      <div class="tiki-pos ${posClass}" style="flex-shrink:0">${pos}</div>
      <div style="width:22px;height:22px;border-radius:5px;background:${t.bg};flex-shrink:0"></div>
      <div style="font-size:13px;font-weight:500">${t.name}</div>
    </div>`;
  });
  html+='</div>';
  document.getElementById('re-board-snapshot').innerHTML=html;
}

function renderRoundScores(results){
  const sorted=[...results].sort((a,b)=>b.earned-a.earned);
  let html='';
  sorted.forEach(r=>{
    const p=r.player;
    const pct=Math.min(100,Math.round(p.score/WIN_SCORE*100));
    html+=`<div class="player-panel" style="padding:12px 14px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
        <div style="display:flex;align-items:center;gap:7px">
          <div class="player-dot" style="background:${p.color}"></div>
          <span style="font-size:13px;font-weight:500">${p.name}</span>
        </div>
        <div style="display:flex;align-items:baseline;gap:4px">
          <span style="font-size:13px;color:var(--tt-muted)">+${r.earned}</span>
          <span style="font-size:16px;font-weight:500;color:${p.color}">${p.score}</span>
          <span style="font-size:11px;color:var(--tt-muted)">/ ${WIN_SCORE}</span>
        </div>
      </div>
      <div style="display:flex;gap:6px;font-size:11px;color:var(--tt-muted);margin-bottom:6px">
        <span>S1 @${r.pos1>0?r.pos1:'—'} → <strong style="color:${r.r1?'var(--tt-gold)':'var(--tt-muted)'}">${r.r1>0?'+'+r.r1:'0'}</strong></span>
        <span>·</span>
        <span>S2 @${r.pos2>0?r.pos2:'—'} → <strong style="color:${r.r2?'var(--tt-gold)':'var(--tt-muted)'}">${r.r2>0?'+'+r.r2:'0'}</strong></span>
        <span>·</span>
        <span>S3 @${r.pos3>0?r.pos3:'—'} → <strong style="color:${r.r3?'var(--tt-gold)':'var(--tt-muted)'}">${r.r3>0?'+'+r.r3:'0'}</strong></span>
      </div>
      <div class="score-bar-bg"><div class="score-bar-fill" style="width:${pct}%;background:${p.color}"></div></div>
    </div>`;
  });
  document.getElementById('re-scores').innerHTML=html;
}

function continueAfterRound(){
  const winner=G.players.find(p=>p.score>=WIN_SCORE);
  if(winner){showWin(winner);return;}
  G.round++;
  G.players.forEach(p=>{p.usedCards=[];p.cards=[...CARDS];});
  assignSecrets();           // ← NEW: reassign fresh secret cards each round
  initBoard(); G.secretIdx=0; showNextSecret();
}

function showWin(winner){
  document.getElementById('win-name').textContent=winner.name+' wins!';
  document.getElementById('win-name').style.color=winner.color;
  const sorted=[...G.players].sort((a,b)=>b.score-a.score);
  let html='<div style="display:flex;flex-direction:column;gap:6px">';
  sorted.forEach((p,i)=>{
    const medal=['🥇','🥈','🥉',''][i]||'';
    html+=`<div style="display:flex;justify-content:space-between;align-items:center;padding:9px 14px;background:var(--tt-surface2);border-radius:var(--tt-radius-sm);border:0.5px solid var(--tt-border)">
      <div style="display:flex;align-items:center;gap:8px">
        <div class="player-dot" style="background:${p.color}"></div>
        <span style="font-weight:500;color:${p.color}">${p.name}</span>
      </div>
      <span style="font-weight:500">${p.score} pts</span>
    </div>`;
  });
  html+='</div>';
  document.getElementById('win-scores').innerHTML=html;
  show('win');
}

function showScores(){
  const sorted=[...G.players].sort((a,b)=>b.score-a.score);
  alert('Scores:\n'+sorted.map(p=>`${p.name}: ${p.score} pts`).join('\n'));
}
// ===================== SECRET CARD MODAL =====================
function openSecretCardModal(){
  const p = currentPlayer();
  // Populate subtitle
  document.getElementById('secret-card-modal-subtitle').textContent =
    p.name + "'s secret objectives";
  // Reuse existing renderSecretCard logic, but target modal element
  const labels = ['Secret 1','Secret 2','Secret 3'];
  const pts = ['+9 pts if at #1','+5 pts if at #1–2','+2 pts if at #1–3'];
  const badgeColors = [
    {bg:'#FAEEDA',text:'#633806'},
    {bg:'#EEEDFE',text:'#3C3489'},
    {bg:'#E1F5EE',text:'#085041'},
  ];
  let html = '';
  p.secret.forEach((idx, i) => {
    const t = TIKI_COLORS[idx];
    const bc = badgeColors[i];
    html += `<div class="secret-tiki-row">
      <div style="width:34px;height:34px;border-radius:8px;background:${t.bg};flex-shrink:0;box-shadow:0 2px 6px rgba(0,0,0,0.18)"></div>
      <div style="flex:1">
        <div style="font-size:13px;font-weight:500">${t.name}</div>
        <div style="font-size:11px;color:var(--tt-muted)">${pts[i]}</div>
      </div>
      <div class="secret-badge" style="background:${bc.bg};color:${bc.text}">${labels[i]}</div>
    </div>`;
  });
  document.getElementById('secret-card-modal-tikis').innerHTML = html;
  document.getElementById('secret-card-modal').classList.add('open');
}

function closeSecretCardModal(event){
  // Close on backdrop click or direct call (close button)
  if(event && event.target !== document.getElementById('secret-card-modal')) return;
  document.getElementById('secret-card-modal').classList.remove('open');
}
setPlayers(2);
</script>

